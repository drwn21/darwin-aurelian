{
  "name": "gmgn-sniper-bot",
  "version": "1.0.0",
  "description": "Autonomous Solana memecoin sniper bot powered by GMGN + Jupiter",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "exec node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
